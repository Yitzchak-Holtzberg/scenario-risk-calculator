# --- Data (large, downloaded from external sources) -----------------------
data/raw/
data/model/
data/*.duckdb
data/*.duckdb.wal
*.csv
*.parquet
!artifacts/**/*.csv
!artifacts/**/*.parquet

# --- Go (api/) -------------------------------------------------------------
api/bin/
api/*.exe
api/*.test
api/vendor/

# --- Node / SvelteKit (web/) -----------------------------------------------
web/node_modules/
web/.svelte-kit/
web/build/
web/.env
web/.env.*
!web/.env.example
# Local-dev copy of frozen artifacts; canonical files live in top-level
# artifacts/. Copy when serving locally:  cp artifacts/*.json web/artifacts/
web/artifacts/

# --- R (training/) ---------------------------------------------------------
training/.Rhistory
training/.RData
training/.Ruserdata
training/.Rproj.user/
training/renv/library/
training/renv/local/
training/renv/staging/
training/_freeze/
training/_site/
training/*.html
!training/model-card-template.html
# Quarto auto-generated sibling directories (per-doc libs, figures, cache)
training/*_files/
training/*_cache/
.Renviron
*.Rcheck/

# --- Editors / OS ----------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Secrets ---------------------------------------------------------------
*.key
*.pem
.env
.env.local
