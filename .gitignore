# --- Data (large, downloaded from external sources) -----------------------
data/raw/
data/model/
data/*.duckdb
data/*.duckdb.wal
*.csv
*.parquet
!artifacts/**/*.csv
!artifacts/**/*.parquet
# Hand-curated supplement values (IMF inflation, Hanke estimates) - tracked
!data/curated/**/*.csv

# --- Go (api/) -------------------------------------------------------------
api/bin/
api/*.exe
api/*.test
api/vendor/

# --- Node / SvelteKit (web/) -----------------------------------------------
web/node_modules/
web/.svelte-kit/
web/build/
web/.env
web/.env.*
!web/.env.example
# Note: web/artifacts/ is committed (duplicate of top-level artifacts/) so
# GitHub Pages can serve the dashboard as a self-contained directory.
# After re-rendering 12_export_artifacts, copy artifacts/*.json -> web/artifacts/.

# --- R (training/) ---------------------------------------------------------
training/.Rhistory
training/.RData
training/.Ruserdata
training/.Rproj.user/
training/renv/library/
training/renv/local/
training/renv/staging/
training/_freeze/
training/_site/
training/*.html
!training/model-card-template.html
# Quarto auto-generated sibling directories (per-doc libs, figures, cache)
training/*_files/
training/*_cache/
.Renviron
*.Rcheck/

# --- Editors / OS ----------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Secrets ---------------------------------------------------------------
*.key
*.pem
.env
.env.local
